PORT=8787

# China: https://open.feishu.cn
# International Lark: https://open.larksuite.com
LARK_BASE_URL=https://open.feishu.cn
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx
LARK_REDIRECT_URI=http://localhost:8787/api/auth/lark/callback

# Optional when LARK_WS_EVENTS=1. Required only for HTTP webhook fallback.
# Example: https://your-tunnel.example.com/api/lark/events
LARK_EVENT_CALLBACK_URL=

# Prefer Feishu/Lark long-connection event receiver in local demo.
# Set to 0 only when you want to rely on HTTP webhook.
LARK_WS_EVENTS=1

# Main path for "user directly starts a Feishu meeting":
# Subscribe events:
#   vc.meeting.all_meeting_started_v1
#   vc.meeting.all_meeting_ended_v1
# Required app permission:
#   vc:meeting.all_meeting:readonly

# Optional path for creating a meeting from this demo:
#   API: /open-apis/vc/v1/reserves/apply
#   permission: vc:reserve
#
# Optional fallback for binding an already opened meeting by meeting URL/no:
#   API: /open-apis/vc/v1/meetings/list_by_no
#   permission: vc:meeting.search:read

# For real minutes search + transcript export.
# If you add or change scopes, log out and log in again in the demo page.
LARK_OAUTH_SCOPES=minutes:minutes.search:read minutes:minutes.basic:read minutes:minutes.transcript:export vc:meeting.search:read

# Usually keep this default for Feishu OAuth.
LARK_OAUTH_AUTHORIZE_PATH=/open-apis/authen/v1/index

# Optional. Used to reject unrelated plaintext callbacks.
LARK_VERIFICATION_TOKEN=xxx

# Demo only supports plaintext event callbacks first.
# Keep Feishu/Lark callback encryption disabled while validating this PoC.
LARK_ENCRYPT_KEY=
