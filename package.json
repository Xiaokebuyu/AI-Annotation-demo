{
  "name": "inkloop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check && vite build",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:ci": "biome check --error-on-warnings .",
    "format": "biome format --write .",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run check && npm run lint:ci && npm run test && vite build",
    "preview": "vite preview",
    "serve": "tsx server/standalone.ts",
    "postinstall": "node scripts/copy-pdfjs-assets.mjs"
  },
  "dependencies": {
    "ink-surface-sdk": "file:../ink-surface-sdk-main",
    "pdfjs-dist": "^4.6.82",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.7.4",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
